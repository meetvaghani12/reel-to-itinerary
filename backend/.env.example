# LLM (OpenAI). OPENAI_BASE_URL is optional — override it (e.g. OpenRouter) to
# use a different provider with the same OpenAI-compatible client.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# YouTube Data API v3
YOUTUBE_API_KEY=AIza-your-youtube-key

# Google Places API (New)
GOOGLE_PLACES_API_KEY=AIza-your-places-key

# Optional: Tour APIs
GETYOURGUIDE_API_KEY=
VIATOR_API_KEY=

# Instagram: path to an exported cookies.txt (Netscape format) from a logged-in
# IG session. This is the reliable, headless-friendly way to fetch reels.
# See README → "Instagram setup". If unset, falls back to reading cookies from
# a locally logged-in browser (INSTAGRAM_BROWSER).
INSTAGRAM_COOKIES_FILE=
INSTAGRAM_BROWSER=chrome

# Database
DATABASE_URL=sqlite+aiosqlite:///./trips.db

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
DEBUG=true
