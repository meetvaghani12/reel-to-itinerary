# App
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./trips.db

# Redis
REDIS_URL=redis://localhost:6379/0

# YouTube Data API v3
YOUTUBE_API_KEY=AIza-your-youtube-key

# Instagram: path to an exported cookies.txt (Netscape) from a logged-in session.
# Falls back to a locally logged-in browser (INSTAGRAM_BROWSER) when unset.
INSTAGRAM_COOKIES_FILE=
INSTAGRAM_BROWSER=chrome
