# App
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./trips.db

# Redis
REDIS_URL=redis://localhost:6379/0

# YouTube Data API v3
YOUTUBE_API_KEY=AIza-your-youtube-key

# Instagram: exported cookies.txt (headless) or browser fallback
INSTAGRAM_COOKIES_FILE=
INSTAGRAM_BROWSER=chrome

# LLM (OpenAI)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Places API (New)
GOOGLE_PLACES_API_KEY=AIza-your-places-key
